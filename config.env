# config.env
GCC_PATH=/usr/bin/gcc
ERLANG_PATH=ERLANG/otp_src_27.0_no_jit/bin/erl
ERLANG_PATH_JIT=ERLANG/otp_src_27.0/bin/erl
JAVA_PATH=java -cp fastutil-8.3.1.jar
JAVA_PATH_JIT=java -cp fastutil-8.3.1.jar -Xint
JAVASCRIPT_PATH=node --jitless
JAVASCRIPT_PATH_JIT=node
LUA_PATH=lua
LUA_PATH_JIT=luajit
PHP_PATH=php-8.4.20 -c php.ini -d opcache.jit=off -d opcache.jit_buffer_size=0
PHP_PATH_JIT=php-8.4.20 -c php.ini -d opcache.enable=1 -d opcache.enable_cli=1 -d opcache.jit=1235 -d opcache.jit_buffer_size=64M
PYTHON_PATH=/opt/pypy3/bin/python3.11
PYTHON_PATH_JIT=/opt/pypy3/bin/pypy3.11
RUBY_PATH=.rbenv/versions/3.4.0/bin/ruby
RUBY_PATH_JIT=.rbenv/versions/3.4.0/bin/ruby --yjit

INPUT_FILE_250k=input250000.txt
INPUT_FILE_1M=input1000000.txt
INPUT_FILE_5M=input5000000.txt
INPUT_FILE_25M=input25000000.txt
